<svg xmlns="http://www.w3.org/2000/svg" width="800" height="450" viewBox="0 0 800 450">
  <rect width="800" height="450" fill="#1a1a2e"/>
  <rect x="0" y="0" width="800" height="6" fill="#c0392b"/>
  <rect x="0" y="444" width="800" height="6" fill="#c0392b"/>
  
  <!-- Decorative lines -->
  <line x1="60" y1="60" x2="740" y2="60" stroke="#c0392b" stroke-width="1" opacity="0.3"/>
  <line x1="60" y1="390" x2="740" y2="390" stroke="#c0392b" stroke-width="1" opacity="0.3"/>

  <!-- Main title -->
  <text x="400" y="160" font-family="Georgia, serif" font-size="36" fill="#ffffff" text-anchor="middle" font-weight="bold">Prekarität. Migration.</text>
  <text x="400" y="210" font-family="Georgia, serif" font-size="36" fill="#ffffff" text-anchor="middle" font-weight="bold">Organizing</text>

  <!-- Subtitle -->
  <text x="400" y="270" font-family="Georgia, serif" font-size="18" fill="#c0392b" text-anchor="middle">Gewerkschaftliche Handlungsstrategien</text>

  <!-- Details -->
  <text x="400" y="330" font-family="Georgia, serif" font-size="14" fill="#aaaaaa" text-anchor="middle">MA Seminar · Sommersemester 2026</text>
  <text x="400" y="355" font-family="Georgia, serif" font-size="14" fill="#aaaaaa" text-anchor="middle">Friedrich Schiller Universität Jena</text>
</svg>
